#!/bin/bash
set -eo pipefail

BROWSER="$1"
CONFIG_FILE="$HOME/.local/share/chezmoi/dot_hammerspoon/lua/browser_config.lua"

if [[ -z "$BROWSER" ]]; then
    echo "Usage: switch-browser <chromium|chrome|edge>"
    exit 1
fi

# Normalize input to lowercase
BROWSER=$(echo "$BROWSER" | tr '[:upper:]' '[:lower:]')

if [[ "$BROWSER" == "chromium" ]]; then
    sed -i '' 's/M.fallback_browser = .*/M.fallback_browser = M.CHROMIUM_BROWSER/' "$CONFIG_FILE"
    echo "Switched to Chromium"
elif [[ "$BROWSER" == "chrome" ]]; then
    sed -i '' 's/M.fallback_browser = .*/M.fallback_browser = M.CHROME_BROWSER/' "$CONFIG_FILE"
    echo "Switched to Google Chrome"
elif [[ "$BROWSER" == "edge" ]]; then
    sed -i '' 's/M.fallback_browser = .*/M.fallback_browser = M.EDGE_BROWSER/' "$CONFIG_FILE"
    echo "Switched to Microsoft Edge"
else
    echo "Unknown browser: $BROWSER"
    echo "Usage: switch-browser <chromium|chrome|edge>"
    exit 1
fi

echo "Applying changes with chezmoi..."
chezmoi apply ~/.hammerspoon/lua/browser_config.lua

# Reload Hammerspoon config
echo "Reloading Hammerspoon..."
if pgrep -x Hammerspoon > /dev/null; then
    # Try to use 'hs' command if available, otherwise just notify
    if command -v hs >/dev/null 2>&1; then
        if ! hs -c "hs.reload()"; then
            echo "Unable to reload Hammerspoon via hs CLI. Restart Hammerspoon to pick up the new config."
        fi
    else
        echo "Command 'hs' not found. Please reload Hammerspoon manually."
    fi
else
    echo "Hammerspoon is not running."
fi
