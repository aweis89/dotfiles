font-family = Comic Code Ligatures
# font-style = light

font-size = 18
theme = light:Gruvbox Light,dark:Everforest Dark Hard
background-image = {{ .chezmoi.homeDir }}/.config/ghostty/wallpaper-sonoma.jpg
background-image-opacity = 0.32
background-image-position = center
background-image-fit = cover
background-opacity = 1
background-opacity-cells = false

# Disable cursor blinking (prevents apps from overriding)
cursor-style-blink = false

window-padding-y = 0
window-padding-x = 0
window-step-resize = true
maximize = false

# Native fullscreen is fine here because the wallpaper is rendered by Ghostty.
fullscreen = true
confirm-close-surface = false
mouse-hide-while-typing = true
custom-shader = ?shaders/cursor_smear.glsl
# auto-update-channel = tip

# keybind = global:ctrl+q=toggle_quick_terminal
quick-terminal-position = right
quick-terminal-size = 45%
