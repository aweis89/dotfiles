#!/bin/sh

set -eu

# Template dependency: change script hash when the managed Pi package list changes.
managed_settings_file=$(mktemp)
managed_packages_file=$(mktemp)
installed_packages_file=$(mktemp)
stale_packages_file=$(mktemp)
trap 'rm -f "$managed_settings_file" "$managed_packages_file" "$installed_packages_file" "$stale_packages_file"' EXIT

cat >"$managed_settings_file" <<'EOF'
{{ include ".chezmoidata/pi-agent-settings.json" }}
EOF

pi_npm_dir=${PI_AGENT_NPM_DIR:-"$HOME/.pi/agent/npm"}
package_json=$pi_npm_dir/package.json

if [ ! -f "$package_json" ]; then
  echo "Pi agent npm package.json not found; skipping package prune: $package_json"
  exit 0
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "jq is required to prune Pi agent packages" >&2
  exit 1
fi

if ! command -v npm >/dev/null 2>&1; then
  echo "npm is required to prune Pi agent packages" >&2
  exit 1
fi

jq -r '
  def package_name:
    sub("^npm:"; "")
    | if startswith("@") then
        capture("^(?<name>@[^/]+/[^@]+)").name
      else
        sub("@.*$"; "")
      end;

  (.packages // [])
  | .[]
  | (if type == "string" then . elif type == "object" then (.source // empty) else empty end)
  | select(startswith("npm:"))
  | package_name
' "$managed_settings_file" | sort -u >"$managed_packages_file"

jq -r '.dependencies // {} | keys[]' "$package_json" | sort -u >"$installed_packages_file"

comm -23 "$installed_packages_file" "$managed_packages_file" >"$stale_packages_file"

if [ ! -s "$stale_packages_file" ]; then
  echo "No stale Pi agent npm packages to prune."
  exit 0
fi

echo "Pruning Pi agent npm packages removed from managed settings:"
sed 's/^/  - /' "$stale_packages_file"

# shellcheck disable=SC2046
(cd "$pi_npm_dir" && npm uninstall --no-audit --no-fund -- $(cat "$stale_packages_file"))
